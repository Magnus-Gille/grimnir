[Unit]
Description=Grimnir registry validation — compare services.json against live state
After=network-online.target munin-memory.service
Wants=network-online.target

[Service]
Type=oneshot
User=magnus
WorkingDirectory=/home/magnus/repos/grimnir
ExecStart=/usr/bin/bash scripts/generate-architecture.sh --validate

# Timeout — cross-host SSH checks can be slow
TimeoutStartSec=120

# Sandboxing — read-only, needs network for SSH and Munin HTTP
ProtectSystem=strict
ReadOnlyPaths=/home/magnus/repos
NoNewPrivileges=yes
PrivateTmp=yes
ProtectHome=read-only
ProtectKernelTunables=yes
ProtectControlGroups=yes
RestrictSUIDSGID=yes
PrivateDevices=yes
RestrictNamespaces=yes
RestrictRealtime=yes
LockPersonality=yes
ProtectClock=yes
ProtectKernelLogs=yes
ProtectKernelModules=yes
SystemCallArchitectures=native

[Install]
WantedBy=default.target
